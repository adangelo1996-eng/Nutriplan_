{
  "rules": {
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": "auth != null && auth.uid == $uid"
      }
    },
    "households": {
      "$hid": {
        ".read": "auth != null",
        ".write": "auth != null && (!data.exists() || data.child('members').child(auth.uid).exists())",
        "members": {
          "$uid": {
            ".write": "auth != null && auth.uid == $uid"
          }
        }
      }
    },
    "householdJoin": {
      ".read": "auth != null",
      ".indexOn": ["nameLower"],
      "$hid": {
        ".write": "auth != null && (!data.exists() || root.child('households').child($hid).child('members').child(auth.uid).exists())"
      }
    }
  }
}
